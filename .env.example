# This project is Bring-Your-Own-Key (BYOK).
# The deployed Worker stores NO secrets — visitors paste their own Bright Data
# token in the UI and it is forwarded per request, never stored.
#
# You only need a token to run the raw API example below from the CLI.
# Get a free token: https://brightdata.com  ->  Settings -> API keys
BRIGHT_DATA_API_TOKEN=your-bright-data-token-here

# Public (not secret) dataset id for the Perplexity Search scraper:
PERPLEXITY_DATASET_ID=gd_m7dhdot1vw9a7gc1n
